<?xml version="1.0"?>
<root main_tree_to_execute="BehaviorTree">
    <!-- ////////// -->
    <BehaviorTree ID="BehaviorTree">
        <ReactiveSequence>
            <Action ID="UpdateMapinfo" sendpasmode="{sendpasmode}"/>
            <Condition ID="IfGameStart" startflag="{startflag}"/>
            <Action ID="GoBase" goal=""/>
            <Action ID="NavigateToPose" goal="{goal}"/>
            <Condition ID="Navvelremap" navvelre="{navvelre}"/>
        </ReactiveSequence>
    </BehaviorTree>
    <!-- ////////// -->
    <TreeNodesModel>
        <Action ID="GoBase">
            <output_port name="goal"/>
        </Action>
        <Condition ID="IfGameStart">
            <output_port name="startflag"/>
        </Condition>
        <Action ID="NavigateToPose">
            <input_port default="{goal}" name="goal">Goal</input_port>
        </Action>
        <Condition ID="Navvelremap">
            <output_port default="{navvelre}" name="navvelre"/>
        </Condition>
        <Action ID="UpdateMapinfo">
            <input_port default="{sendpasmode}" name="sendpasmode"/>
        </Action>
    </TreeNodesModel>
    <!-- ////////// -->
</root>
