<?xml version="1.0"?>
<root main_tree_to_execute="BehaviorTree">
    
    <BehaviorTree ID="BehaviorTree">
        <Sequence name="导航主序列">
            
            <UpdateMapinfo name="更新地图" sendpasmode="{sendpasmode}" />
            
            <IfGameStart name="检查开始" startflag="{startflag}" />
            
            
            <GoBase name="决策目标" goal="{goal}" />
            
            <NavigateToPose name="导航到目标" goal="{goal}" />
            
        </Sequence>
    </BehaviorTree>
    
    <TreeNodesModel>
        <Action ID="UpdateMapinfo">
            <input_port name="sendpasmode" default="0"/>
        </Action>
        
        <Condition ID="IfGameStart">
            <input_port name="startflag" default="false"/>
        </Condition>
        
        
        <Action ID="GoBase">
            <output_port name="goal" type="geometry_msgs::msg::PoseStamped"/>
        </Action>
        
        <Action ID="NavigateToPose">
            <input_port name="goal" type="geometry_msgs::msg::PoseStamped"/>
        </Action>
    </TreeNodesModel>
    
</root>