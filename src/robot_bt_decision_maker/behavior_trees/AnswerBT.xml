<?xml version="1.0" encoding="UTF-8"?>
<root main_tree_to_execute="MainTree">

    <BehaviorTree ID="MainTree">
        <Sequence name="主序列">
            
            <!-- 1. 更新地图信息（输出各种信息到黑板） -->
            <UpdateMapinfo name="更新地图"
                star_name="{star_name}"
                sendpasmode="{sendpasmode}" />
            
            <!-- 2. 检查游戏是否开始 -->
            <IfGameStart name="检查游戏开始"
                startflag="{startflag}" />
            
            <!-- 3. 重新映射导航速度 -->
            <Navvelremap name="速度映射"
                navvelre="{navvelre}" />
            
            <!-- 4. 决策目标点（输出 goal_x, goal_y 到黑板） -->
            <GoBase name="决策目标"
                goal_x="{goal_x}"
                goal_y="{goal_y}" />
            
            
            
        </Sequence>
    </BehaviorTree>

</root>